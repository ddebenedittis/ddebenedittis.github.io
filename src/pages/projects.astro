---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">My Projects</div>
  </div>

  <HorizontalCard
    title="Control of Quadrupedal Robots on Soft Terrains"
    img="https://raw.githubusercontent.com/ddebenedittis/media/main/rviz_legged/rviz_legged_trot.webp"
    desc="Model-based control for quadrupedal robots moving on compliant terrains."
    url="https://github.com/ddebenedittis/control_quadrupeds_soft_contacts"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Hierarchical Constraint-Based Control of Multi-Robot Systems"
    img="https://raw.githubusercontent.com/ddebenedittis/media/main/hierarchical_optimization_mpc/coverage_9.webp"
    desc="Control of heterogeneous multi-robot fleet using hierarchical optimization and quadratic programming."
    url="https://github.com/ddebenedittis/hierarchical_optimization_mpc"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Multi-Robot Systems Reinforcement Learning"
    img="https://raw.githubusercontent.com/ddebenedittis/media/main/multi_robot_jaxrl/cluttered_env_single_robot_16_9.webp"
    desc="Control of multi-robot systems using reinforcement learning and JAX."
    url="https://github.com/ddebenedittis/multi_robot_jaxrl"
    badge="JAX"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Docker Container for ROS (1 and 2), GUIs, and NVIDIA GPUs"
    img="https://raw.githubusercontent.com/ddebenedittis/media/main/docker_ros_nvidia/docker_ros_480x270.webp"
    desc="Docker container to be used with ROS 1 or ROS 2. Supports the usage of GUIs and NVIDIA GPUs."
    url="https://github.com/ddebenedittis/docker_ros_nvidia"
    badge="Docker"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="UAV Sensor Fusion"
    img="https://raw.githubusercontent.com/ddebenedittis/media/main/uni-sgn-auv_sensor_fusion/sc1_10s.webp"
    desc="Indirect Extended Sequential Kalman Filter for multi sensor fusion on UAVs."
    url="https://github.com/ddebenedittis/uni-sgn-auv_sensor_fusion"
  />

