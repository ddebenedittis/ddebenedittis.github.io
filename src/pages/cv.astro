    </li>
  </ul> -->

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-5 columns-2 mx-6">
    <li>Python</li>
    <li>C++</li>
    <li>MATLAB & Simulink</li>
    <li>ROS 1 and ROS 2</li>
    <li>Gazebo</li>
    <li>Docker</li>
    <li>Git</li>
  </ul>
</BaseLayout>
