---
import { CollectionEntry, getCollection, render } from "astro:content";
import { BlogSchema } from "../../content.config";
import PubLayout from "../../layouts/PubLayout.astro";
import createSlug from "../../lib/createSlug"

export async function getStaticPaths() {
  const postEntries = await getCollection("publications");
  return postEntries.map((entry) => ({
    params: { slug: createSlug(entry.data.title, entry.id) },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"publications">;
}

const { entry } = Astro.props;
const post: BlogSchema = entry.data;
const { Content } = await render(entry);
---

<PubLayout
  title={post.title}
  auth={post.auth}
  journal={post.journal}
  description={post.description}
  pubDate={post.pubDate}
  heroImage={post.heroImage}
  updatedDate={post.updatedDate}
  badge={post.badge}
  tags={post.tags}
>
  <Content />
</PubLayout>
