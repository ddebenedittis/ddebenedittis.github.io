---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalPublication from "../../components/HorizontalPublication.astro";
import { getCollection } from "astro:content";
import createSlug from "../../lib/createSlug"

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("publications");
  posts.sort((a, b) => {
  const dateA = a.data.pubDate.toLowerCase() === "under review" ? Infinity : new Date(a.data.pubDate);
  const dateB = b.data.pubDate.toLowerCase() === "under review" ? Infinity : new Date(b.data.pubDate);

  return dateB - dateA;
});
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout title="Publications" sideBarActiveItemID="publications">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Publications</div>
  </div>

  {
    page.data.length === 0 ? (
      <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
        <p class="font-bold">Sorry!</p>
        <p>There are no publications to show at the moment. Check back later!</p>
      </div>
    ) : (
      <ul>
        {page.data.map((pub) => (
          <>
            <HorizontalPublication
              title={pub.data.title}
              img={pub.data.heroImage}
              desc={pub.data.description}
              auth={pub.data.auth}
              journal={pub.data.journal}
              date={pub.data.pubDate}
              slug={createSlug(pub.data.title, pub.id)}
              url={pub.data.url ? pub.data.url : "/publications/" + createSlug(pub.data.title, pub.id)}
              tag_url={"/publications/tag"}
              target="_self"
              badge={pub.data.badge}
              tags={pub.data.tags}
              paperUrl={pub.data.paperUrl}
              githubUrl={pub.data.githubUrl}
              bibtex={pub.data.bibtex}
            />
            <div class="divider my-0" />
          </>
        ))}
      </ul>
    )
  }

<div class="flex justify-between w-full">
  <div class="flex-1 flex justify-start">
    {page.url.prev ? (
      <a href={page.url.prev} class="btn btn-ghost my-10">
        <svg
          class="h-6 w-6 fill-current md:h-8 md:w-8"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
        </svg>
        Recent posts
      </a>
    ) : <div class="w-32"></div>}
  </div>

  <div class="flex-1 flex justify-end">
    {page.url.next ? (
      <a href={page.url.next} class="btn btn-ghost my-10">
        Older Posts
        <svg
          class="h-6 w-6 fill-current md:h-8 md:w-8"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
        </svg>
      </a>
    ) : <div class="w-32"></div>}
  </div>
</div>
  </div>
</BaseLayout>
