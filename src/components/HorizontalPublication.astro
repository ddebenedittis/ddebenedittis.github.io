---
const {
  title,
  img,
  desc,
  auth,
  journal,
  date,
  url,
  badge,
  tags,
  target = "_blank",
  paperUrl,
  githubUrl,
  bibtex
} = Astro.props;
import { Image } from "astro:assets";
---

<div
  class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%] group"
>
  <div class="flex flex-col md:flex-row gap-4 items-start md:items-center">
    <a href={url} target={target}>
      <div class="hero-content flex-col md:flex-row">
        {img && (
          <Image
            src={img}
            width={750}
            height={422}
            format="webp"
            alt={title}
            class="max-w-full md:max-w-[13rem] rounded-lg"
          />
        )}
        <div class="grow w-full">
          <h1 class="text-xl font-bold relative group">
            <span class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent transition-opacity duration-[250ms] ease-in-out opacity-0 group-hover:opacity-100">
              {title}
            </span>
            <span class="relative text-inherit transition-opacity duration-[250ms] ease-in-out group-hover:opacity-0">
              {title}
            </span>
            {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
          </h1>          
          <div>
            <span class="text-1xl mr-1"><em>{journal}</em> — {date}</span>
          </div>
          <p class="py-1 text-1xl">{desc}</p>
          <div class="card-actions justify-end">
            {tags &&
              tags.map((tag) => (
                <a href={url} class="badge badge-outline">
                  {tag}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </a>

    <div class="flex flex-col items-end gap-2 md:-ml-10">
      {paperUrl && (
        <a
          href={paperUrl}
          target="_blank"
          class="btn btn-ghost text-xl"
          aria-label="Publication"
        >
          <svg 
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 576 512"
            style="fill: currentColor;"
          >
            <path d="M0 80l0 48c0 17.7 14.3 32 32 32l16 0 48 0 0-80c0-26.5-21.5-48-48-48S0 53.5 0 80zM112 32c10 13.4 16 30 16 48l0 304c0 35.3 28.7 64 64 64s64-28.7 64-64l0-5.3c0-32.4 26.3-58.7 58.7-58.7L480 320l0-192c0-53-43-96-96-96L112 32zM464 480c61.9 0 112-50.1 112-112c0-8.8-7.2-16-16-16l-245.3 0c-14.7 0-26.7 11.9-26.7 26.7l0 5.3c0 53-43 96-96 96l176 0 96 0z"/>
          </svg>
        </a>
      )}
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          class="btn btn-ghost text-xl"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 496 512"
            style="fill: currentColor;"
          >
            <path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3 .3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5 .3-6.2 2.3zm44.2-1.7c-2.9 .7-4.9 2.6-4.6 4.9 .3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3 .7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3 .3 2.9 2.3 3.9 1.6 1 3.6 .7 4.3-.7 .7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3 .7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3 .7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"/>
          </svg>
        </a>
      )}
      {bibtex && (
        <label
          for="bibtex-modal"
          class="btn btn-ghost flex items-center gap-2"
          onClick={(e) => e.stopPropagation()}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 448 512"
            style="fill: currentColor;"
          >
            <path d="M96 0C43 0 0 43 0 96L0 416c0 53 43 96 96 96l288 0 32 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l0-64c17.7 0 32-14.3 32-32l0-320c0-17.7-14.3-32-32-32L384 0 96 0zm0 384l256 0 0 64L96 448c-17.7 0-32-14.3-32-32s14.3-32 32-32zm32-240c0-8.8 7.2-16 16-16l192 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-192 0c-8.8 0-16-7.2-16-16zm16 48l192 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-192 0c-8.8 0-16-7.2-16-16s7.2-16 16-16z"/>
          </svg>
        </label>
      )}
    </div>
  </div>
</div>

{bibtex && (
  <>
    <input type="checkbox" id="bibtex-modal" class="modal-toggle" />
    <div class="modal">
      <div class="modal-box relative w-[960px] h-[480] max-w-full max-h-full">
        <label for="bibtex-modal" class="btn btn-sm btn-circle absolute right-2 top-2">
          ✕
        </label>
        <h3 class="font-bold text-lg mb-2">Citation</h3>
        <pre id="bibtex-content" class="bg-base-200 p-4 rounded text-lg overflow-auto">{bibtex.trim()}</pre>

        <button id="copy-bibtex-btn" class="btn btn mt-4">
          Copy
        </button>
      </div>
    </div>
  </>
)}

<script is:client>
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtn = document.getElementById('copy-bibtex-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const code = document.getElementById('bibtex-content').innerText;
        navigator.clipboard.writeText(code);
      });
    }
  });
</script>
