---
const { url } = Astro.props;
---

<div class="iframe-wrapper">
  <iframe
    id="myIframe"
    class="slide-deck"
    src={url}
    allowfullscreen
    width="1000"
    height="562.5">
  </iframe>

  <button onclick="goFullscreen()" class="fullscreen-icon-btn" aria-label="Fullscreen">
    <svg
      viewBox="0 0 24 24"
      width="24"
      height="24"
      fill="none"
      stroke="white"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="fullscreen-icon"
    >
      <!-- top-left -->
      <polyline points="3,9 3,3 9,3" />
      <!-- top-right -->
      <polyline points="15,3 21,3 21,9" />
      <!-- bottom-left -->
      <polyline points="3,15 3,21 9,21" />
      <!-- bottom-right -->
      <polyline points="15,21 21,21 21,15" />
    </svg>
  </button>
</div>

<style>
  .iframe-wrapper {
    position: relative;
    width: 1000px;
    height: 562.5px;
  }

  .slide-deck {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .fullscreen-icon-btn {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background-color: rgba(0, 0, 0, 0.5);
    border: none;
    border-radius: 4px;
    padding: 8px;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .fullscreen-icon-btn:hover {
    background-color: rgba(0, 0, 0, 0.8);
  }

  .fullscreen-icon {
    transition: transform 0.3s ease;
  }

  .fullscreen-icon-btn:hover .fullscreen-icon {
    transform: scale(1.3);
  }
</style>

<script is:global>
  function goFullscreen() {
    const iframe = document.getElementById('myIframe');
    if (iframe.requestFullscreen) {
      iframe.requestFullscreen();
    } else if (iframe.webkitRequestFullscreen) {
      iframe.webkitRequestFullscreen();
    } else if (iframe.msRequestFullscreen) {
      iframe.msRequestFullscreen();
    }
  }
</script>
